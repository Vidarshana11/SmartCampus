# ========================================
# Smart Campus API - Configuration
# ========================================

# Application Name
spring.application.name=SmartCampusAPI
server.port=8081
server.servlet.context-path=/

# ========================================
# DATABASE CONFIGURATION
# ========================================
# MySQL/MariaDB connection details

spring.datasource.url=jdbc:mysql://localhost:3306/smart_campus_db?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver
spring.datasource.username=smartcampus
spring.datasource.password=smartcampus123

# Connection Pool Settings
spring.datasource.hikari.maximum-pool-size=10
spring.datasource.hikari.minimum-idle=5
spring.datasource.hikari.connection-timeout=30000

# ========================================
# JPA/HIBERNATE CONFIGURATION
# ========================================

spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=false
spring.jpa.properties.hibernate.format_sql=true
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.MySQL8Dialect

# ========================================
# LOGGING CONFIGURATION
# ========================================

logging.level.root=INFO
logging.level.com.smartcampus.api=DEBUG
logging.level.org.springframework.security=DEBUG

# ========================================
# JWT (JSON Web Token) CONFIGURATION
# ========================================

jwt.secret=404E635266556A586E3272357538782F413F4428472B4B6250645367566B5970
jwt.expiration=86400000
jwt.refresh-expiration=604800000

# ========================================
# PASSWORD RESET CONFIGURATION
# ========================================
# Users receive a 6-digit code via email to reset their password
# Code expires after the configured TTL
app.password-reset.ttl-minutes=30
app.password-reset.frontend-reset-url=http://localhost:5173/reset-password

# ========================================
# EMAIL VERIFICATION CONFIGURATION
# ========================================
# New registrations receive a 6-digit code to verify their email
# Code expires after the configured TTL (default: 24 hours)
app.email-verification.ttl-minutes=1440
app.email-verification.frontend-verify-url=http://localhost:5173/verify-email

# ========================================
# SMTP MAIL CONFIGURATION
# ========================================
# Required for email verification and password reset
#
# For Gmail:
# 1. Enable 2-Factor Authentication on your Google account
# 2. Go to Google Account → Security → App passwords
# 3. Generate an app password for "Mail"
# 4. Use that 16-character password below (NOT your regular password)
#
# For development: Codes are logged to console if SMTP is not configured

# ========================================
# SMTP MAIL CONFIGURATION
# ========================================
spring.mail.host=smtp.gmail.com
spring.mail.port=587
spring.mail.username=vidajaya2@gmail.com
spring.mail.password=xdka kqxp nsbe qrvr
spring.mail.properties.mail.smtp.auth=true
spring.mail.properties.mail.smtp.starttls.enable=true
app.mail.from=vidajaya2@gmail.com


# Other SMTP providers:
# Outlook: spring.mail.host=smtp-mail.outlook.com
# Yahoo:   spring.mail.host=smtp.mail.yahoo.com

# ========================================
# OAUTH2 GOOGLE CONFIGURATION
# ========================================
# IMPORTANT: Get credentials from https://console.cloud.google.com/
# See README.md for detailed setup instructions

# 1. Go to https://console.cloud.google.com/
# 2. Create a new project
# 3. Enable Google+ API
# 4. Create OAuth2 Web Application credentials
# 5. Add redirect URI: http://localhost:8080/login/oauth2/code/google
# 6. Copy Client ID and Client Secret below:

spring.security.oauth2.client.registration.google.client-id=YOUR_GOOGLE_CLIENT_ID
spring.security.oauth2.client.registration.google.client-secret=YOUR_GOOGLE_CLIENT_SECRET
spring.security.oauth2.client.registration.google.scope=profile,email
spring.security.oauth2.client.provider.google.authorization-uri=https://accounts.google.com/o/oauth2/v2/auth
spring.security.oauth2.client.provider.google.token-uri=https://www.googleapis.com/oauth2/v4/token
spring.security.oauth2.client.provider.google.user-info-uri=https://www.googleapis.com/oauth2/v2/userinfo
spring.security.oauth2.client.provider.google.user-name-attribute=email

# ========================================
# CORS CONFIGURATION
# ========================================

cors.allowed-origins=http://localhost:5175,http://localhost:3000,http://127.0.0.1:5175
cors.allowed-methods=GET,POST,PUT,DELETE,OPTIONS,PATCH
cors.allowed-headers=*
cors.max-age=3600
cors.allow-credentials=true

# ========================================
# FILE UPLOAD CONFIGURATION
# ========================================

spring.servlet.multipart.max-file-size=10MB
spring.servlet.multipart.max-request-size=30MB
upload.dir=uploads/

# ========================================
# JACKSON (JSON SERIALIZATION) CONFIGURATION
# ========================================

spring.jackson.serialization.write-dates-as-timestamps=false
spring.jackson.time-zone=UTC
spring.jackson.default-property-inclusion=non_null

# ========================================
# ERROR HANDLING
# ========================================

server.error.include-message=always
server.error.include-binding-errors=always
server.error.include-stacktrace=on-param
server.error.include-exception=false
